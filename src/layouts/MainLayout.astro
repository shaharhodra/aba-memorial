---
const { title } = Astro.props;
---
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">
    <!-- סרגל ניווט -->
    <nav class="bg-white shadow-md sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-gray-800">לזכרו של אבא</a>
        <div class="flex gap-6">
          <a href="/gallery" class="hover:text-amber-600 transition font-medium">גלריה</a>
          <a href="/recipes" class="hover:text-amber-600 transition font-medium">מתכונים</a>
          <a href="/videos" class="hover:text-amber-600 transition font-medium">סרטונים</a>
          <a href="/guestbook" class="hover:text-amber-600 transition font-medium">זיכרונות</a>
        </div>
      </div>
    </nav>

    <!-- תוכן הדף -->
    <div class="flex-grow">
      <slot />
    </div>

    <footer class="py-8 text-center text-gray-400 bg-white border-t mt-12">
      <p>מונצח באהבה על ידי שחר והמשפחה</p>
    </footer>
  </body>
</html>