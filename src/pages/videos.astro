---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="סרטונים וזיכרונות">
  <main class="max-w-4xl mx-auto py-12 px-6 text-center">
    <h1 class="text-5xl font-bold text-amber-400 mb-12">סרטונים ורגעים</h1>
    
    <div class="aspect-video bg-black/40 rounded-3xl flex items-center justify-center border-2 border-dashed border-white/20">
      <p class="text-gray-500 text-xl font-medium">בקרוב נעלה כאן סרטונים של אבא</p>
    </div>

    <div class="mt-8 text-gray-400">
      <p>כאן נוכל להוסיף בעתיד קישורים מיוטיוב או סרטונים ישירים מהנייד.</p>
    </div>
  </main>
</MainLayout>