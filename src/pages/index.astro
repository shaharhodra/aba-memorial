---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="לזכרו של אבא">
  <!-- רקע מעודן לכל הדף -->
  <main class="min-h-screen bg-slate-50">
    
    <!-- Hero Section: תמונה וכותרת -->
    <section class="relative w-full h-[70vh] flex items-end justify-center overflow-hidden border-b-8 border-white shadow-lg">
      <img 
        src="/father-smile.jpg" 
        alt="אבא יצחק" 
        class="absolute inset-0 w-full h-full object-cover object-top"
      />
      <!-- שכבת הצללה לתחתית התמונה כדי שהטקסט יהיה קריא -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
      
      <div class="relative text-center pb-12 px-4">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-2 drop-shadow-lg">לזכרו של יצחק</h1>
        <p class="text-xl md:text-2xl text-slate-200 italic font-light">"האדם אינו אלא תבנית נוף מולדתו"</p>
      </div>
    </section>

    <!-- תוכן מרכזי -->
    <div class="max-w-4xl mx-auto px-4 -mt-10 relative z-10">
      <article class="bg-white p-8 md:p-16 rounded-[2.5rem] shadow-xl border border-slate-100">
        
        <div class="space-y-8 text-xl md:text-2xl text-right leading-relaxed text-slate-700">
          <p class="first-letter:text-5xl first-letter:font-bold first-letter:ml-3 first-letter:text-slate-400">
            אבא היה עמוד התווך של המשפחה שלנו. אדם של אנשים, של חיוך רחב ושל לב ענק שרואים בכל תמונה שלו.
          </p>
          <p>
            הוא אהב את החיים, אהב לארח, ותמיד ידע להפוך כל ארוחה פשוטה לחגיגה של טעמים – במיוחד כשהיה מדובר בבשר טוב על האש או במקלובה המפורסמת שלו.
          </p>
          <div class="border-r-4 border-slate-200 pr-6 py-2 my-10 italic text-slate-500">
            אוהבים ומתגעגעים, שחר והמשפחה
          </div>
        </div>

        <!-- כפתורי ניווט מעוצבים למובייל -->
        <nav class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-16">
          <a href="/gallery" class="flex items-center justify-center gap-3 bg-slate-800 text-white py-5 rounded-2xl font-bold text-xl hover:bg-slate-700 transition-all shadow-md active:scale-95">
             📸 גלריית תמונות
          </a>
          <a href="/guestbook" class="flex items-center justify-center gap-3 bg-white border-2 border-slate-800 text-slate-800 py-5 rounded-2xl font-bold text-xl hover:bg-slate-50 transition-all shadow-sm active:scale-95">
             ✍️ ספר אורחים
          </a>
        </nav>
      </article>
    </div>

    <!-- פוטר קטן בסוף -->
    <footer class="py-12 text-center text-slate-400 text-sm">
      מונצח באהבה על ידי המשפחה • 2026
    </footer>
  </main>
</MainLayout>